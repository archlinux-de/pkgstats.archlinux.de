    "compilerOptions": {
        "strict": true,
        "noEmit": true,
        "target": "ES2022",
        "module": "ESNext",
        "moduleResolution": "bundler",
        "allowImportingTsExtensions": true,
        "isolatedModules": true,
        "skipLibCheck": true
    },
    "include": ["src"]
}
